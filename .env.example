# ============================================================
# Firefly III - Core Application
# ============================================================
APP_ENV=local
APP_DEBUG=false
APP_KEY=SomeRandomStringOf32CharsExactly
SITE_OWNER=you@example.com
DEFAULT_LANGUAGE=en_US
DEFAULT_LOCALE=equal
TZ=America/Toronto
TRUSTED_PROXIES=**

# ============================================================
# Database - PostgreSQL
# ============================================================
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=change_me_strong_password

# ============================================================
# Firefly III - Access Token
# Generate after first login: Options -> Profile -> OAuth -> Personal Access Tokens
# ============================================================
FIREFLY_III_ACCESS_TOKEN=your_personal_access_token_here

# ============================================================
# Cron Token (exactly 32 characters)
# Generate: head /dev/urandom | LC_ALL=C tr -dc 'A-Za-z0-9' | head -c 32
# ============================================================
STATIC_CRON_TOKEN=your_32_char_cron_token_here_xxx

# ============================================================
# AI Service - LLM Keys (use one or both)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# Which LLM provider to use: "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# ============================================================
# AI Service - Categorization Settings
# ============================================================
# Your custom spending categories (comma-separated)
CUSTOM_CATEGORIES=Food,Groceries,Transportation,Entertainment,Subscriptions,Housing,Utilities,Healthcare,Shopping,Chess,SaaS Tools,Income,Transfer,Other

# Confidence threshold (0.0 - 1.0) below which we flag for manual review
CATEGORY_CONFIDENCE_THRESHOLD=0.7

# How many transactions to batch per LLM call (saves tokens)
BATCH_SIZE=20

# ============================================================
# AI Service - Pattern Detection
# ============================================================
# Days to look back for pattern analysis
PATTERN_LOOKBACK_DAYS=90

# Variance % that counts as a "recurring" transaction match
RECURRING_VARIANCE_PERCENT=10

# ============================================================
# Dashboard
# ============================================================
VITE_API_URL=http://localhost:8000
VITE_FIREFLY_URL=http://localhost:8080
